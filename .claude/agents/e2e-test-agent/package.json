    "@anthropic-ai/sdk": "^0.52.0",
    "@vue/compiler-dom": "^3.5.38",
    "@vue/compiler-sfc": "^3.5.38",
    "commander": "^12.0.0",
    "playwright": "^1.45.0",
    "ts-morph": "^24.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@stylistic/eslint-plugin": "^2.13.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.9"
  }
